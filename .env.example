# =============================================================
# HENG — promenljive okruženja
# Kopirajte u .env.local i popunite. .env.local se ne komituje.
# =============================================================

# ---------- Supabase (obavezno za prodavnicu i admin panel) ----------
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PAŽNJA: service_role ključ zaobilazi RLS. Koristi se isključivo na serveru
# (kreiranje porudžbina, upita, seed). Nikada ga ne stavljajte u promenljivu
# sa NEXT_PUBLIC_ prefiksom i nikada ga ne komitujte.
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Sajt ----------
# Koristi se za canonical adrese, Open Graph, sitemap i robots.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------- Email (opciono) ----------
# Bez ovih vrednosti aplikacija radi normalno — obaveštenja se preskaču
# i evidentiraju u logu.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
